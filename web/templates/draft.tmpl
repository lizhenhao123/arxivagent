{{define "draft.tmpl"}}
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
  <style>
    body { font-family: "Microsoft YaHei", sans-serif; margin: 0; background: #f8fafc; color: #0f172a; }
    .wrap { max-width: 1120px; margin: 0 auto; padding: 28px 20px 64px; }
    .top { margin-bottom: 24px; }
    .top a { color: #2563eb; text-decoration: none; }
    .hero { background: #fff; border-radius: 20px; padding: 28px; box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08); }
    .hero h1 { margin: 0 0 12px; font-size: 34px; line-height: 1.3; }
    .meta { color: #475569; font-size: 14px; }
    .summary { margin-top: 14px; font-size: 16px; line-height: 1.8; color: #334155; }
    .grid { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 24px; margin-top: 24px; }
    .content, .side { background: #fff; border-radius: 20px; padding: 24px; box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08); }
    .content h1, .content h2, .content h3 { color: #0f172a; }
    .content p { line-height: 1.85; color: #1e293b; }
    .tag { display: inline-block; background: #dbeafe; color: #1d4ed8; border-radius: 999px; padding: 6px 12px; margin: 0 8px 8px 0; font-size: 13px; }
    .figure { margin-bottom: 20px; }
    .figure img { width: 100%; border-radius: 14px; background: #e2e8f0; display: block; }
    .caption { margin-top: 8px; color: #475569; font-size: 13px; line-height: 1.6; }
    .side h3 { margin-top: 0; }
    @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top"><a href="/">返回首页</a></div>
    <section class="hero">
      <h1>{{.Post.Title}}</h1>
      <div class="meta">审核状态：{{.Post.ReviewStatus}} | arXiv：{{.Post.ArxivID}} | <a href="{{.Post.SourceURL}}" target="_blank" rel="noreferrer">原文链接</a></div>
      {{if .Post.Summary}}<div class="summary">{{.Post.Summary}}</div>{{end}}
      <div style="margin-top: 14px;">
        {{range .Post.Tags}}<span class="tag">{{.}}</span>{{end}}
      </div>
    </section>

    <section class="grid">
      <article class="content">
        {{if .Post.RenderedHTML}}
          {{.Post.RenderedHTML}}
        {{else}}
          <pre>{{.Post.MarkdownContent}}</pre>
        {{end}}
      </article>

      <aside class="side">
        <h3>实验图像</h3>
        {{if .Post.Assets}}
          {{range .Post.Assets}}
            {{if eq .AssetType "FIGURE"}}
            <div class="figure">
              <img src="/assets/{{.ID}}" alt="{{if .Caption}}{{.Caption}}{{else}}figure{{end}}">
              <div class="caption">
                {{if .FigureIndex}}Figure {{.FigureIndex}}{{end}}
                {{if .PageNo}} | 第 {{.PageNo}} 页{{end}}
                {{if .Caption}}<br>{{.Caption}}{{end}}
              </div>
            </div>
            {{end}}
          {{end}}
        {{else}}
          <div>暂无图像。</div>
        {{end}}
      </aside>
    </section>
  </div>
</body>
</html>
{{end}}

